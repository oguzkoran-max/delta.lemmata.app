    affiliation: "Ankara University"
    email: "koran@ankara.edu.tr"
license: MIT
url: "https://delta.lemmata.app"
keywords:
  - stylometry
  - digital humanities
  - Burrows's Delta
  - literary studies
  - reproducibility
