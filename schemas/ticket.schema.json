{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delta.lemmata.app/schemas/ticket.schema.json",
  "title": "Delta Development Ticket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ticket_id",
    "title",
    "status",
    "opened_at_utc",
    "closed_at_utc",
    "objective",
    "scope",
    "non_goals",
    "dependencies",
    "claim_ids",
    "threat_ids",
    "decision_ids",
    "prompt_event_ids",
    "commit_ids",
    "human_owner",
    "acceptance_owner",
    "implementation_agents",
    "acceptance",
    "changed_files",
    "commands",
    "blockers"
  ],
  "properties": {
    "schema_version": {"enum": ["1.0.0", "1.1.0"]},
    "ticket_id": {"type": "string", "pattern": "^P[0-9]{3}$"},
    "title": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["planned", "in-progress", "blocked", "complete"]
    },
    "opened_at_utc": {"type": "string", "format": "date-time"},
    "closed_at_utc": {"type": ["string", "null"], "format": "date-time"},
    "objective": {"type": "string", "minLength": 1},
    "scope": {"$ref": "#/$defs/string_array"},
    "non_goals": {"$ref": "#/$defs/string_array"},
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^P[0-9]{3}$"}
    },
    "claim_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^CE-[0-9]{2}$"}
    },
    "threat_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^(SEC|RP|EPI)-[0-9]{2}$"}
    },
    "decision_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^HD-[0-9]{8}-[0-9]{4}$"}
    },
    "prompt_event_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^PE-[0-9]{8}-[0-9]{4}$"}
    },
    "commit_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"}
    },
    "run_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^RUN-[0-9]{8}-[0-9]{4}$"}
    },
    "supplemental_evidence": {"$ref": "#/$defs/string_array"},
    "human_owner": {"type": "string", "minLength": 1},
    "acceptance_owner": {"type": "string", "minLength": 1},
    "implementation_agents": {"$ref": "#/$defs/string_array"},
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "criterion", "status", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^P[0-9]{3}-AC-[0-9]{2}$"},
          "criterion": {"type": "string", "minLength": 1},
          "status": {
            "type": "string",
            "enum": ["pending", "passed", "failed", "not-applicable"]
          },
          "evidence": {"$ref": "#/$defs/string_array"}
        }
      }
    },
    "changed_files": {"$ref": "#/$defs/string_array"},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "result", "evidence"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "exit_code": {"type": "integer", "minimum": 0, "maximum": 255},
          "result": {"type": "string", "minLength": 1},
          "evidence": {"type": ["string", "null"]}
        }
      }
    },
    "blockers": {"$ref": "#/$defs/string_array"}
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": "1.1.0"}}},
      "then": {"required": ["run_ids", "supplemental_evidence"]}
    },
    {
      "if": {"properties": {"status": {"const": "complete"}}},
      "then": {"properties": {"closed_at_utc": {"type": "string"}}}
    }
  ],
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
