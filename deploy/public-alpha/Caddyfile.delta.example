# Add only after the local stack, read-only host inventory, and pre-change
# Lemmata baseline pass. Validate the complete host Caddyfile before reload.
delta.lemmata.app {
    @invalid_host not host delta.lemmata.app
    respond @invalid_host 421

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        -Server
    }

    reverse_proxy 127.0.0.1:8502 {
        header_up Host delta.lemmata.app
        header_up X-Forwarded-Host delta.lemmata.app
        header_up X-Forwarded-Proto https
        # Defense-in-depth: pin X-Forwarded-For to the real client address.
        # Caddy already ignores client-supplied X-Forwarded-* by default (its
        # trusted_proxies list is empty), so the gateway's per-client rate and
        # connection limits are not spoofable out of the box. Setting it here
        # makes that trust explicit and keeps it even if a broader
        # trusted_proxies policy is ever added.
        header_up X-Forwarded-For {http.request.remote.host}
    }
}
