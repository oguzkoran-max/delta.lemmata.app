# Copy to /etc/delta-public-alpha/deployment.env with root:root ownership and 0600 mode.
# Replace both placeholders before docker compose or systemd is allowed to start.
DELTA_IMAGE=<immutable-delta-image-reference-with-sha256-digest>
DELTA_BUILD_ID=<40-character-source-commit>
DELTA_RUNTIME_ENV_FILE=/etc/delta-public-alpha/runtime.env
