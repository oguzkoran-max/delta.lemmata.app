# Delta v0.1 has no external AI, analytics, login, or persistent project storage.
DELTA_ENV=development
DELTA_LOG_LEVEL=INFO
DELTA_EXTERNAL_NETWORK=disabled

# Production requires a pre-created private directory owned by the app process.
# DELTA_RUNTIME_ROOT=/var/lib/delta/runtime

# Generate these independently with: openssl rand -hex 32
# Never reuse either secret or commit a real value.
# DELTA_JOB_OWNER_SECRET_HEX=<64-lowercase-hex-characters>
# DELTA_PREPARATION_AUTHORITY_SECRET_HEX=<different-64-lowercase-hex-characters>
